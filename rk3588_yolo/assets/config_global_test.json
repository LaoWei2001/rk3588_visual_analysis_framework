{
    "schema_version": 2,
    "global": {
        "model_path": "assets/yolov5n.rknn",
        "label_path": "assets/labels.txt",
        "enable_display": 1,
        "disp_width": 1280,
        "disp_height": 720,
        "tile_rows": 2,
        "tile_cols": 2,
        "max_fps": 25,
        "queue_size": 2,
        "channel_threads": 1,
        "npu_cores": 3,
        "obj_thresh": 0.3,
        "nms_thresh": 0.45,
        "detect_classes": [],
        "tracker_enable": 1,
        "tracker_iou_thresh": 0.3,
        "tracker_max_miss": 30,
        "tracker_min_hits": 3,
        "performance_display": 1,
        "playback_fps": 25,
        "enable_pause_key": 1,
        
        "//comment_global_logics": "3 个全局逻辑实例并行运行, 用于验证多实例 / channels 分组 / 热重载",
        "global_logics": [
            {
                "//comment": "实例 1: 跨通道联动报警 — 覆盖全部 4 路, 任 ≥2 路报警时上传联动告警",
                "enable": true,
                "logic": "global_example",
                "channels": [],
                "poll_interval_ms": 200
            },
            {
                "//comment": "实例 2: 健康监控 — 周期打印各通道帧/框/状态, 仅监控 CH0 和 CH1",
                "enable": true,
                "logic": "global_default",
                "channels": [
                    0,
                    1
                ],
                "poll_interval_ms": 500
            },
            {
                "//comment": "实例 3: 演示热重载 — 默认关闭, 可在运行时把 enable 改 true 看线程动态启动",
                "enable": false,
                "logic": "global_default",
                "channels": [
                    2,
                    3
                ],
                "poll_interval_ms": 1000
            }
        ]
    },
    "//comment_channels": "4 路均使用本地 2.mp4 循环播放, logic_person_alarm 为 global_example 提供 PersonAlarmState",
    "channels": [
        {
            "id": 0,
            "enable": true,
            "stream": {
